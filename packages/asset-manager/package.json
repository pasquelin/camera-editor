{
  "name": "@media-studio/asset-manager",
  "version": "0.0.0",
  "description": "Façade Asset Manager du SDK Media Studio — registry de ResourcePack et gating licence (headless ; cœur dans core). Voir docs/08-ASSET-MANAGER.md.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@media-studio/core": "workspace:*"
  },
  "devDependencies": {
    "@media-studio/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
