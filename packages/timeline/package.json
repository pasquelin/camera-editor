{
  "name": "@media-studio/timeline",
  "version": "0.0.0",
  "description": "Timeline du SDK Media Studio — conversion temps↔pixels et moteur de snap (headless). Voir docs/05-TIMELINE.md.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": { "@media-studio/core": "workspace:*" },
  "devDependencies": {
    "@media-studio/core": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": { "access": "public" }
}
