{
  "name": "@media-studio/export-engine",
  "version": "0.0.0",
  "description": "Pipeline d'export offline du SDK Media Studio — dégradation licence, sélection moteur principal/fallback (headless). Voir docs/09-EXPORT-ENGINE.md.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "@media-studio/core": "workspace:*",
    "@media-studio/background-jobs": "workspace:*"
  },
  "devDependencies": {
    "@media-studio/core": "workspace:*",
    "@media-studio/background-jobs": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": { "access": "public" }
}
